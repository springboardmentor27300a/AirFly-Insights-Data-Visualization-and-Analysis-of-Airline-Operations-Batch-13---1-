import folium

airport_delay = flights.groupby("ORIGIN_AIRPORT")["DEPARTURE_DELAY"].mean().reset_index()

airport_map = flights.merge(
    airport_delay,
    left_on="AIRPORT",
    right_on="ORIGIN_AIRPORT"
)

delay_map = folium.Map(location=[39,-98], zoom_start=4)

for _, row in airport_map.iterrows():

    color = "red" if row["DEPARTURE_DELAY"] > 10 else "green"

    folium.CircleMarker(
        location=[row["LATITUDE"], row["LONGITUDE"]],
        radius=5,
        popup=f"{row['AIRPORT']} Delay: {row['DEPARTURE_DELAY']:.2f}",
        color=color,
        fill=True
    ).add_to(delay_map)

delay_map

